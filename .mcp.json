{
  "mcpServers": {
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ]
    },
    "nuget": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "NuGet.Mcp.Server@1.4.3",
        "--yes"
      ]
    },
    "binlog": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "Microsoft.AITools.BinlogMcp",
        "--source",
        "https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json",
        "--yes",
        "--prerelease"
      ]
    }
  }
}
