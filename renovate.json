{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "node:lts"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.devcontainer/Dockerfile$"],
      "matchStrings": ["ARG GO_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.devcontainer/Dockerfile$"],
      "matchStrings": ["ARG NODE_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.devcontainer/Dockerfile$"],
      "matchStrings": ["ARG GOAT_VERSION=(?<currentValue>[^\\n]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "bluesky-social/goat"
    }
  ]
}
