{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "labels": ["dependencies"],
  "extends": [
    "config:best-practices",
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "group:definitelyTyped",
    "group:dotNetCore",
    "helpers:pinGitHubActionDigestsToSemver",
    "security:openssf-scorecard"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "pinDigests": true,
  "ignorePaths": [
    ".github/workflows/*.lock.yml"
  ],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDatasources": ["nuget"],
      "automerge": true,
      "description": "Auto-merge minor/patch NuGet updates (safety is gated by CI)"
    },
    {
      "matchDepNames": [
        "Microsoft.NETFramework.ReferenceAssemblies",
        "System.Memory",
        "System.Threading.Tasks.Extensions"
      ],
      "abandonmentThreshold": null,
      "description": "Suppress abandonment alert - finished legacy package, not truly abandoned"
    },
    {
      "matchDatasources": ["devcontainer-feature"],
      "automerge": true,
      "description": "Auto-merge minor/patch updates for official devcontainer features",
      "matchDepNames": [
        "/^ghcr\\.io/devcontainers//"
      ]
    },
    {
      "matchDepNames": ["dotnet-sdk"],
      "groupName": ".NET SDK version",
      "description": "Keep global.json and devcontainer.json dotnet feature version in sync"
    },
    {
      "matchDatasources": ["github-tags"],
      "automerge": true,
      "description": "Auto-merge minor/patch/pin/digest updates for trusted GitHub Actions",
      "matchDepNames": [
        "/^actions//",
        "/^microsoft//",
        "/^github//",
        "/^advanced-security//"
      ]
    },
    {
      "matchDatasources": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "description": "Auto-merge dev-only npm minor/patch"
    },
    {
      "matchFileNames": [".devcontainer/Dockerfile"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "description": "Auto-merge dev container CLI tools (minor/patch)"
    },
    {
      "matchDepNames": ["submodules/atproto"],
      "matchDatasources": ["git-refs"],
      "automerge": true,
      "description": "Auto-merge atproto submodule updates"
    },
    {
      "matchUpdateTypes": ["pin", "pinDigest"],
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Allow automerge pin updates"
    },
    {
      "matchUpdateTypes": ["rollback", "replacement"],
      "minimumReleaseAge": null,
      "automerge": false,
      "commitMessagePrefix": "[cautionable]",
      "description": "Report cautionable updates"
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "description": "Don't automerge major updates"
    }
  ],
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "json",
      "managerFilePatterns": [
        "/^\\.devcontainer/devcontainer\\.json$/"
      ],
      "matchStrings": [
        "{\"depName\": \"dotnet-sdk\", \"currentValue\": features.`ghcr.io/devcontainers/features/dotnet:2`.version, \"datasource\": \"dotnet-version\"}"
      ],
      "description": "devcontainer feature's dotnet SDK version, synced with global.json via groupName"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "minimumReleaseAge": null,
    "addLabels": ["security"]
  }
}
