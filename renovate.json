{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": ["dependencies"],
  "extends": [
    "config:best-practices",
    "group:definitelyTyped",
    "group:dotNetCore",
    "helpers:pinGitHubActionDigestsToSemver",
    "security:openssf-scorecard"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/[Dd]ockerfile*",
        "**/*.[Dd]ockerfile*"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (?:lookupName|packageName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\s(?:ENV|ARG)\\s+[A-Za-z0-9_]+?_VERSION[ =][\"']?(?<currentValue>.+?)[\"']?\\s"
      ]
    }
  ],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepNames": ["node"],
      "allowedVersions": "/^(\\d*[02468])\\./",
      "description": "Node.js LTS (even major) only"
    },
    {
      "matchDatasources": ["nuget"],
      "internalChecksFilter": "strict",
      "minimumReleaseAge": "3 days",
      "description": "Wait 3 days before updating NuGet packages"
    },
    {
      "matchDatasources": ["nuget"],
      "matchSourceUrls": [
        "https://github.com/dotnet/**",
        "https://github.com/microsoft/**"
      ],
      "minimumReleaseAge": "0 days",
      "description": "Trust NuGet packages sourced from Microsoft GitHub organizations"
    }
  ]
}
