{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": ["dependencies"],
  "extends": [
    "config:best-practices",
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "group:definitelyTyped",
    "group:dotNetCore",
    "helpers:pinGitHubActionDigestsToSemver",
    "security:openssf-scorecard",
    "schedule:automergeDaily"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "pinDigests": true,
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepNames": ["node"],
      "allowedVersions": "/^(\\d*[02468])\\./",
      "description": "Node.js LTS (even major) only"
    },
    {
      "matchDatasources": ["nuget"],
      "matchSourceUrls": [
        "https://github.com/dotnet/**",
        "https://github.com/microsoft/**"
      ],
      "groupName": "nuget microsoft",
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Auto-merge minor/patch updates from Microsoft GitHub organizations"
    },
    {
      "matchDepNames": [
        "Microsoft.NETFramework.ReferenceAssemblies",
        "System.Memory",
        "System.Threading.Tasks.Extensions"
      ],
      "abandonmentThreshold": null,
      "description": "Suppress abandonment alert - finished legacy package, not truly abandoned"
    },
    {
      "matchDatasources": ["devcontainer-feature"],
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Auto-merge minor/patch updates for official devcontainer features",
      "matchDepNames": [
        "/^ghcr\\.io/devcontainers//"
      ]
    },
    {
      "matchDatasources": ["github-tags"],
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Auto-merge minor/patch/pin/digest updates for trusted GitHub Actions",
      "matchDepNames": [
        "/^actions//",
        "/^microsoft//",
        "/^github//",
        "/^advanced-security//"
      ]
    },
    {
      "matchDatasources": ["docker"],
      "matchRegistryUrls": ["mcr.microsoft.com"],
      "groupName": "docker mcr.microsoft.com",
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Auto-merge minor/patch/pin/digest updates for Microsoft Container Registry images"
    },
    {
      "matchDatasources": ["npm"],
      "matchDepNames": ["renovate"],
      "schedule": ["* * * * 1"],
      "description": "Reduce renovate update frequency to weekly"
    },
    {
      "matchDepNames": ["submodules/atproto"],
      "matchDatasources": ["git-refs"],
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Auto-merge atproto submodule updates"
    },
    {
      "matchUpdateTypes": ["pin", "pinDigest"],
      "minimumReleaseAge": null,
      "automerge": true,
      "description": "Allow automerge pin updates"
    },
    {
      "matchUpdateTypes": ["rollback", "replacement"],
      "minimumReleaseAge": null,
      "automerge": false,
      "commitMessagePrefix": "[cautionable]",
      "description": "Report cautionable updates"
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "description": "Don't automerge major updates"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.mcp\\.json$/"
      ],
      "matchStrings": ["\"(?<depName>@[\\w-]+/[\\w-]+)@(?<currentValue>[\\d][\\d.]*)\""],
      "datasourceTemplate": "npm",
      "description": "MCP server npm packages"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.mcp\\.json$/"
      ],
      "matchStrings": ["\"(?<depName>[\\w][\\w.]*?)@(?<currentValue>[\\d][\\d.]*)\""],
      "datasourceTemplate": "nuget",
      "description": "MCP server NuGet packages"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "minimumReleaseAge": null,
    "addLabels": ["security"]
  }
}
