<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../../../Generators/Generators.Package/build/BlueBlaze.Generator.props" />

  <PropertyGroup>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <UsePolyfills>true</UsePolyfills>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>

  <PropertyGroup>
    <BlueBlazeGeneratorRunAsBuildTask>true</BlueBlazeGeneratorRunAsBuildTask>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../../Generators/Generators.MSBuild/Generators.MSBuild.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <LexiconDocument Include="../../../submodules/atproto/lexicons/com/atproto/**/*.json" />
  </ItemGroup>

  <Import Project="../../../Generators/Generators.Package/build/BlueBlaze.Generator.targets" />

</Project>
