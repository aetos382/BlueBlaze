{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(dotnet build *)",
      "Bash(dotnet nuget why *)",
      "Bash(dotnet package list *)",
      "Bash(dotnet package search *)",
      "Bash(dotnet restore *)",
      "Bash(dotnet test *)",
      "Bash(git config get *)",
      "Bash(git config list *)",
      "Bash(git fetch *)",
      "Bash(git remote get-url *)",
      "Bash(gh * list *)",
      "Bash(gh * view *)",
      "Bash(gh search *)",
      "Bash(gh skill search *)",
      "Bash(npm config get *)",
      "Bash(npm config list *)",
      "Bash(npm ls *)",
      "Bash(npm explain *)",
      "Bash(npm view *)",
      "Bash(op read *)",
      "mcp__context7",
      "mcp__nuget__get_latest_package_version",
      "mcp__nuget__get_package_context",
      "mcp__github__get_commit",
      "mcp__github__get_copilot_job_status",
      "mcp__github__get_file_contents",
      "mcp__github__get_label",
      "mcp__github__get_latest_release",
      "mcp__github__get_me",
      "mcp__github__get_release_by_tag",
      "mcp__github__get_tag",
      "mcp__github__get_team_members",
      "mcp__github__get_teams",
      "mcp__github__issue_read",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__list_issue_types",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__list_releases",
      "mcp__github__list_repository_collaborators",
      "mcp__github__list_tags",
      "mcp__github__pull_request_read",
      "mcp__github__search_code",
      "mcp__github__search_commits",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__search_repositories",
      "mcp__github__search_users",
      "mcp__plugin_dotnet-msbuild_binlog",
      "mcp__plugin_microsoft-docs_microsoft-learn"
    ],
    "deny": [
      "Edit(**/*.lock.json)",
      "Edit(**/*-lock.json)",
      "Edit(**/*.lock.yml)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "disableClaudeAiConnectors": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File .claude/hooks/build-if-cs-changed.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File .claude/hooks/if-cs-changed.ps1"
          }
        ]
      }
    ]
  },
  "language": "Japanese"
}
