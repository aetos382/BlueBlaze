<Project>
  <PropertyGroup>
    <BlueBlazeGeneratorRunAsBuildTask Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == ''">false</BlueBlazeGeneratorRunAsBuildTask>
  </PropertyGroup>

  <PropertyGroup Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == 'true'">

    <_BlueBlazeGeneratorBuildTaskAssemblyFileDirectoryBase>$(MSBuildThisFileDirectory)..</_BlueBlazeGeneratorBuildTaskAssemblyFileDirectoryBase>
    <_BlueBlazeGeneratorBuildTaskAssemblyFileRuntimeDirectoryName Condition="'$(MSBuildRuntimeType)' == 'Full'">full</_BlueBlazeGeneratorBuildTaskAssemblyFileRuntimeDirectoryName>
    <_BlueBlazeGeneratorBuildTaskAssemblyFileRuntimeDirectoryName Condition="'$(MSBuildRuntimeType)' == 'Core'">core</_BlueBlazeGeneratorBuildTaskAssemblyFileRuntimeDirectoryName>
    <_BlueBlazeGeneratorBuildTaskAssemblyFileName>BlueBlaze.Generators.MSBuild.dll</_BlueBlazeGeneratorBuildTaskAssemblyFileName>
    <_BlueBlazeGeneratorBuildTaskAssemblyFilePath Condition="'$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)' == ''">$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(_BlueBlazeGeneratorBuildTaskAssemblyFileDirectoryBase)', 'tasks', '$(_BlueBlazeGeneratorBuildTaskAssemblyFileRuntimeDirectoryName)', '$(_BlueBlazeGeneratorBuildTaskAssemblyFileName)'))))</_BlueBlazeGeneratorBuildTaskAssemblyFilePath>

    <_BlueBlazeGeneratorBuildTaskRuntime>CurrentRuntime</_BlueBlazeGeneratorBuildTaskRuntime>
    <_BlueBlazeGeneratorBuildTaskRuntime Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(MSBuildVersion)', '18.0'))">NET</_BlueBlazeGeneratorBuildTaskRuntime>

  </PropertyGroup>

  <UsingTask TaskName="BlueBlazeGenerateSourceCode"
             AssemblyFile="$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)"
             Runtime="$(_BlueBlazeGeneratorBuildTaskRuntime)"
             TaskFactory="TaskHostFactory"
             Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == 'true'"/>

</Project>
