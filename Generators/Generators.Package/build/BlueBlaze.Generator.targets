<Project>
  <PropertyGroup>
    <BlueBlazeGeneratorRunAsBuildTask Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == ''">false</BlueBlazeGeneratorRunAsBuildTask>
  </PropertyGroup>

  <PropertyGroup Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == 'true'">
    <_BlueBlazeGeneratorBuildTaskAssemblyFilePath Condition="'$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)' == ''">$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..', 'tasks', '$(TargetFramework)', 'BlueBlaze.Generators.MSBuild.dll'))</_BlueBlazeGeneratorBuildTaskAssemblyFilePath>
    <_BlueBlazeGeneratorBuildTaskRuntime>CurrentRuntime</_BlueBlazeGeneratorBuildTaskRuntime>
    <_BlueBlazeGeneratorBuildTaskRuntime Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(MSBuildVersion)', '18.0'))">NET</_BlueBlazeGeneratorBuildTaskRuntime>
  </PropertyGroup>

  <UsingTask TaskName="BlueBlazeGenerateSourceCode"
             AssemblyFile="$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)"
             Runtime="$(_BlueBlazeGeneratorBuildTaskRuntime)"
             TaskFactory="TaskHostFactory"
             Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == 'true'"/>

</Project>
