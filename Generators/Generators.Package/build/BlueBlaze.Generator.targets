<Project>
  <PropertyGroup>
    <BlueBlazeGeneratorRunAsBuildTask Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == ''">false</BlueBlazeGeneratorRunAsBuildTask>
  </PropertyGroup>

  <PropertyGroup Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == 'true'">

    <_BlueBlazeGeneratorBuildTaskAssemblyFileName>BlueBlaze.Generators.MSBuild.dll</_BlueBlazeGeneratorBuildTaskAssemblyFileName>
    <_BlueBlazeGeneratorBuildTaskAssemblyFileDirectory Condition="'$(_BlueBlazeGeneratorBuildTaskAssemblyFileDirectory)' == ''">BlueBlaze.Generators.MSBuild.dll</_BlueBlazeGeneratorBuildTaskAssemblyFileDirectory>
    <_BlueBlazeGeneratorBuildTaskAssemblyFilePath>$([MSBuild]::EnsureTrailingSlash($(_BlueBlazeGeneratorBuildTaskAssemblyFileDirectory)))$(_BlueBlazeGeneratorBuildTaskAssemblyFileName)</_BlueBlazeGeneratorBuildTaskAssemblyFilePath>

    <_BlueBlazeGeneratorBuildTaskRuntime>*</_BlueBlazeGeneratorBuildTaskRuntime>
    <_BlueBlazeGeneratorBuildTaskRuntime Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(MSBuildVersion)', '18.0'))">NET</_BlueBlazeGeneratorBuildTaskRuntime>

  </PropertyGroup>

  <UsingTask TaskName="BlueBlazeGenerateSourceCode"
             AssemblyFile="$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)"
             Runtime="$(_BlueBlazeGeneratorBuildTaskRuntime)"
             TaskFactory="TaskHostFactory"
             Condition="'$(BlueBlazeGeneratorRunAsBuildTask)' == 'true'"/>

</Project>
