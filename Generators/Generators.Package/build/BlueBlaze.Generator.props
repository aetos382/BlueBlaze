<Project>

  <PropertyGroup>
    <AdditionalFileItemNames>
      $(AdditionalFileItemNames);
      LexiconDocument
    </AdditionalFileItemNames>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <LexiconDocument>
      <IsLexiconDocument>true</IsLexiconDocument>
    </LexiconDocument>
  </ItemDefinitionGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="BlueBlazeGeneratorRunAsBuildTask" />
    <CompilerVisibleItemMetadata Include="LexiconDocument" MetadataName="IsLexiconDocument"/>
  </ItemGroup>

</Project>
