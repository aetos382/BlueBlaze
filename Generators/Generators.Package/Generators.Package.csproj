<Project Sdk="Microsoft.Build.NoTargets">

  <PropertyGroup>
    <TargetFrameworks>net481;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <PackageId>BlueBlaze.Generator</PackageId>
    <DevelopmentDependency>true</DevelopmentDependency>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <IncludeSymbols>false</IncludeSymbols>
    <NoWarn>$(NoWarn);NU5100</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Generators.Roslyn\Generators.Roslyn.csproj">
      <PrivateAssets>all</PrivateAssets>
      <Pack>true</Pack>
      <PackagePath>analyzers/dotnet/roslyn5.0/cs</PackagePath>
    </ProjectReference>
    <ProjectReference Include="..\Generators.MSBuild\Generators.MSBuild.csproj">
      <PrivateAssets>all</PrivateAssets>
      <Pack>true</Pack>
      <PackagePath Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">tasks/full</PackagePath>
      <PackagePath Condition="'$(TargetFrameworkIdentifier)' == '.NETCoreApp'">tasks/core</PackagePath>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Update="@(ProjectReference)">
      <SkipGetTargetFrameworkProperties>false</SkipGetTargetFrameworkProperties>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="build/*">
      <Pack>true</Pack>
      <PackagePath>build/</PackagePath>
    </None>
  </ItemGroup>

  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>
      $(TargetsForTfmSpecificContentInPackage);
      GetBuildOutputForPackaging
    </TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Target Name="GetBuildOutputForPackaging" AfterTargets="ResolveProjectReferences">

    <ItemGroup>
      <_ReferencedProject Include="@(ProjectReference)" Condition="'%(Pack)' == 'true'">
        <ProjectFullPath>%(FullPath)</ProjectFullPath>
      </_ReferencedProject>
    </ItemGroup>

    <MSBuild Projects="@(_ReferencedProject)"
             Targets="GetProjectPurpose"
             BuildInParallel="true"
             RemoveProperties="TargetFramework">

      <Output TaskParameter="TargetOutputs" ItemName="_ProjectFullPathWithPurpose" />

    </MSBuild>

    <ItemGroup>
      <_NonMSBuildTask Include="%(_ProjectFullPathWithPurpose.OriginalItemSpec)" Condition="'%(_ProjectFullPathWithPurpose.ProjectPurpose)' != 'MSBuildTask'" />
      <_MSBuildTaskProject Include="@(_ReferencedProject)" Exclude="@(_NonMSBuildTask)"/>
    </ItemGroup>

    <MSBuild
      Projects="@(_MSBuildTaskProject)"
      Properties="TargetFramework=$(TargetFramework);InnerTargets=GetTargetPath;Configuration=$(Configuration);Platform=$(Platform)"
      Condition="'@(_MSBuildTaskProject)' != ''">

      <Output TaskParameter="TargetOutputs" ItemName="_BuildOutputFiles" />

    </MSBuild>

    <ItemGroup>
      <TfmSpecificPackageFile Include="@(_BuildOutputFiles)">
        <PackagePath>%(PackagePath)</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>

  </Target>

</Project>
