<Project>

  <PropertyGroup>
    <BlueBlazeGeneratorRunMode Condition="'$(BlueBlazeGeneratorRunMode)' == ''">Roslyn</BlueBlazeGeneratorRunMode>
    <AdditionalFileItemNames>
      $(AdditionalFileItemNames);
      LexiconDocument
    </AdditionalFileItemNames>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <LexiconDocument>
      <IsLexiconDocument>true</IsLexiconDocument>
      <Visible>true</Visible>
    </LexiconDocument>
  </ItemDefinitionGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="BlueBlazeGeneratorRunMode" />
    <CompilerVisibleProperty Include="BlueBlazeGeneratedCodeNamespace"/>
    <CompilerVisibleProperty Include="BlueBlazeGeneratorGenerateTypeInfo"/>
    <CompilerVisibleProperty Include="BlueBlazeGeneratorForceEmitAotAttributes"/>
    <CompilerVisibleProperty Include="TargetFramework"/>
    <CompilerVisibleItemMetadata Include="LexiconDocument" MetadataName="IsLexiconDocument"/>
  </ItemGroup>

</Project>
