<Project>
  <PropertyGroup>
    <_BlueBlazeGeneratorBuildTaskRuntime>CurrentRuntime</_BlueBlazeGeneratorBuildTaskRuntime>
    <_BlueBlazeGeneratorBuildTaskRuntime Condition="$([MSBuild]::VersionGreaterThanOrEquals('$(MSBuildVersion)', '18.0'))">NET</_BlueBlazeGeneratorBuildTaskRuntime>

    <_BlueBlazeGeneratorBuildTaskAssemblyFileName>BlueBlaze.LexiconGenerator.MSBuild.dll</_BlueBlazeGeneratorBuildTaskAssemblyFileName>

    <!-- NuGet パッケージからインストールされた場合 -->
    <_BlueBlazeGeneratorBuildTaskAssemblyFilePath Condition="'$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)' == '' and Exists('$(MSBuildThisFileDirectory)../tasks/$(TargetFramework)/$(_BlueBlazeGeneratorBuildTaskAssemblyFileName)')">$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..', 'tasks', '$(TargetFramework)', '$(_BlueBlazeGeneratorBuildTaskAssemblyFileName)'))</_BlueBlazeGeneratorBuildTaskAssemblyFilePath>
  </PropertyGroup>

  <!--
    ローカルビルド / CI (UseArtifactsOutput) の場合。
    $(ArtifactsPivots) は Sdk.targets 側（Microsoft.NET.DefaultOutputPaths.targets）で設定されるが、
    このファイルは Sdk.props と Sdk.targets の間（プロジェクト本体）でインポートされるため、
    インポート時点では $(ArtifactsPivots) が未定義。
    代わりに $(Configuration) と $(TargetFramework) から直接 Pivots を構築する。
    LexiconGenerator.MSBuild は常にマルチターゲットなので消費側の $(TargetFramework) をそのまま使う。
  -->
  <PropertyGroup Condition="'$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)' == ''">
    <_BlueBlazeGeneratorBuildTaskArtifactsPivots>$(Configuration.ToLowerInvariant())</_BlueBlazeGeneratorBuildTaskArtifactsPivots>
    <_BlueBlazeGeneratorBuildTaskArtifactsPivots Condition="'$(TargetFramework)' != ''">$(_BlueBlazeGeneratorBuildTaskArtifactsPivots)_$(TargetFramework.ToLowerInvariant())</_BlueBlazeGeneratorBuildTaskArtifactsPivots>
    <_BlueBlazeGeneratorBuildTaskAssemblyFilePath>$([MSBuild]::NormalizePath('$(ArtifactsPath)', 'bin', 'LexiconGenerator.MSBuild', '$(_BlueBlazeGeneratorBuildTaskArtifactsPivots)', '$(_BlueBlazeGeneratorBuildTaskAssemblyFileName)'))</_BlueBlazeGeneratorBuildTaskAssemblyFilePath>
  </PropertyGroup>

  <PropertyGroup>
    <BlueBlazeGenerateLexiconSourceCodeTaskDebugBreakOnExecute>false</BlueBlazeGenerateLexiconSourceCodeTaskDebugBreakOnExecute>
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)BlueBlaze.LexiconGenerator.MSBuild.Debug.targets" Condition="Exists('$(MSBuildThisFileDirectory)BlueBlaze.LexiconGenerator.MSBuild.Debug.targets')" />

  <UsingTask TaskName="BlueBlazeGenerateSourceCode"
             AssemblyFile="$(_BlueBlazeGeneratorBuildTaskAssemblyFilePath)"
             Runtime="$(_BlueBlazeGeneratorBuildTaskRuntime)"
             TaskFactory="TaskHostFactory"/>

  <Target Name="BlueBlazeGenerateLexiconSourceCode"
          DependsOnTargets="$(BlueBlazeGenerateLexiconSourceCodeDependsOn)"
          BeforeTargets="CoreCompile">

    <BlueBlazeGenerateSourceCode
      LexiconDocuments="@(LexiconDocument)"
      OutputPath="$(IntermediateOutputPath)GeneratedSources/BlueBlaze.LexiconGenerator/"
      GeneratedCodeNamespace="$(BlueBlazeGeneratedCodeNamespace)"
      GenerateTypeInfo="$(BlueBlazeGeneratorGenerateTypeInfo)"
      DebugBreakOnExecute="$(BlueBlazeGenerateLexiconSourceCodeTaskDebugBreakOnExecute)">

      <Output TaskParameter="GeneratedFiles" ItemName="GeneratedLexiconSources" />

    </BlueBlazeGenerateSourceCode>

    <ItemGroup>
      <Compile Include="@(GeneratedLexiconSources)" />
    </ItemGroup>
  </Target>

</Project>
