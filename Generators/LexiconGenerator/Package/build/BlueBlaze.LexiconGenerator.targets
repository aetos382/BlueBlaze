<Project>

  <PropertyGroup>
    <BlueBlazeGeneratedCodeNamespace Condition="'$(BlueBlazeGeneratedCodeNamespace)' == ''">$(RootNamespace).Generated</BlueBlazeGeneratedCodeNamespace>
    <BlueBlazeGeneratorForceEmitAotAttributes Condition="'$(BlueBlazeGeneratorForceEmitAotAttributes)' == ''">false</BlueBlazeGeneratorForceEmitAotAttributes>
  </PropertyGroup>

  <Target Name="_BBWarnInvalidRunMode" BeforeTargets="CoreCompile">
    <Warning Condition="'$(BlueBlazeGeneratorRunMode)' != 'Roslyn' and '$(BlueBlazeGeneratorRunMode)' != 'MSBuild'"
             Text="The MSBuild property 'BlueBlazeGeneratorRunMode' has an invalid value '$(BlueBlazeGeneratorRunMode)'. Valid values are 'Roslyn' and 'MSBuild'." />
  </Target>

  <Import Project="BlueBlaze.LexiconGenerator.MSBuild.targets" Condition="'$(BlueBlazeGeneratorRunMode)' == 'MSBuild'" />

</Project>
