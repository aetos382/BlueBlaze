{
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "overrideCommand": true,
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10.0.300"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/powershell:2": {},
    "ghcr.io/devcontainers/features/node:2": {},
    "ghcr.io/stuartleeks/dev-container-features/shell-history:0": {}
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "LANG": "ja_JP.UTF-8",
    "TZ": "Asia/Tokyo",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "DISABLE_AUTOUPDATER": "1",
    "NUGET_PACKAGES": "/home/vscode/.nuget/packages",
    "WORKSPACE": "${containerWorkspaceFolder}"
  },
  "updateContentCommand": "bash .devcontainer/updateContent.sh",
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "mounts": [
    {
      "type": "volume",
      "source": "claude-code-config-${devcontainerId}",
      "target": "/home/vscode/.claude"
    },
    {
      "type": "volume",
      "source": "nuget-packages-${devcontainerId}",
      "target": "/home/vscode/.nuget/packages"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "-dbaeumer.vscode-eslint"
      ]
    }
  }
}
